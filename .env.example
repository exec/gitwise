# Gitwise Configuration
GITWISE_PORT=3000
GITWISE_HOST=0.0.0.0
GITWISE_SECRET=change-me-in-production

# PostgreSQL
GITWISE_DB_HOST=localhost
GITWISE_DB_PORT=5432
GITWISE_DB_USER=gitwise
GITWISE_DB_PASSWORD=gitwise
GITWISE_DB_NAME=gitwise
GITWISE_DB_SSLMODE=disable

# Redis
GITWISE_REDIS_HOST=localhost
GITWISE_REDIS_PORT=6379
GITWISE_REDIS_PASSWORD=
GITWISE_REDIS_DB=0

# Git repository storage
GITWISE_REPOS_PATH=./data/repos

# Embeddings (optional — disable to skip AI features)
# GITWISE_EMBEDDINGS_ENABLED=false
# GITWISE_EMBEDDINGS_PROVIDER=openai
# GITWISE_EMBEDDINGS_MODEL=text-embedding-3-small
# GITWISE_EMBEDDINGS_API_KEY=sk-...
